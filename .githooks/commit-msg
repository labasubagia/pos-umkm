#!/bin/sh
# commit-msg hook: validate commit message and reject generic messages
# Usage: placed in .githooks/commit-msg and made executable

MSG_FILE="$1"
if [ -z "$MSG_FILE" ]; then
  echo "commit-msg hook: missing message file arg" >&2
  exit 1
fi

MSG=$(sed -n '1,1p' "$MSG_FILE")
FULL_MSG=$(cat "$MSG_FILE")

# Reject the default Copilot CLI commit message (case-insensitive)
if echo "$FULL_MSG" | grep -iq "commit from copilot cli"; then
  echo "ERROR: Generic commit message 'Commit from Copilot CLI' is not allowed." >&2
  echo "Please write a descriptive Conventional Commit (type(scope): subject). See docs/COMMITS.md" >&2
  exit 1
fi

# Basic Conventional Commits subject line check (type or revert)
if ! echo "$MSG" | grep -Eq '^(feat|fix|test|refactor|docs|chore|ci|style|perf|revert)(\([a-z0-9._\-\/]+\))?: .{1,72}$'; then
  echo "ERROR: Commit subject does not follow required format: type(scope): subject" >&2
  echo "Allowed types: feat, fix, test, refactor, docs, chore, ci, style, perf, revert" >&2
  echo "Example: feat(cashier): add change calculation to cash payment flow" >&2
  exit 1
fi

# Accept the commit
exit 0
